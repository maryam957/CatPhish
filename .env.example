# Copy this file to .env and fill in real values before running the backend.
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Required — JWT signing secret (min 32 chars of random hex)
CATPHISH_JWT_SECRET=REPLACE_WITH_64_HEX_CHARS

# Required — HMAC key for server-side audit log (64 hex chars = 32 bytes)
CATPHISH_AUDIT_KEY=REPLACE_WITH_64_HEX_CHARS

# Optional — HMAC secret for signed report verification (min 32 chars)
CATPHISH_REPORT_SECRET=REPLACE_WITH_64_HEX_CHARS

# Server port (default 3000)
PORT=3000

# Set to 'production' to enforce HTTPS-only cookies (HSTS)
NODE_ENV=development

# DEMO ONLY — enables /api/auth/demo-activate (skip email verification)
# NEVER set this to true in production
CATPHISH_DEMO_MODE=true

# Optional — extra CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://yourfrontend.example.com
